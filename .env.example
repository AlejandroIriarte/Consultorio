# ─────────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://consultorio:consultorio_dev@localhost:5432/consultorio"

# ─────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
# Generá con: openssl rand -hex 64
JWT_SECRET="cambia_esto_por_un_secreto_muy_largo_y_aleatorio"

# ─────────────────────────────────────────────
# 2FA (TOTP)
# ─────────────────────────────────────────────
# Generá con: openssl rand -hex 32
TOTP_ENCRYPTION_KEY="cambia_esto_por_clave_aes256"

# ─────────────────────────────────────────────
# NEXTAUTH (Frontend)
# ─────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generá con: openssl rand -hex 32
NEXTAUTH_SECRET="cambia_esto_por_secreto_nextauth"

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
ALLOWED_ORIGINS="localhost:3000,consultorio.app"
PORT=3001
NODE_ENV="development"

# ─────────────────────────────────────────────
# EMAIL (Resend)
# ─────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@consultorio.app"

# ─────────────────────────────────────────────
# SMS / WHATSAPP (Twilio)
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxx"
TWILIO_PHONE_NUMBER="+1xxxxxxxxxx"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# ─────────────────────────────────────────────
# ARCHIVOS (AWS S3)
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID="AKIAxxxxxxx"
AWS_SECRET_ACCESS_KEY="xxxxxxx"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="consultorio-files"
